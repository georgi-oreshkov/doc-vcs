    },
    {
      "name": "Diff Flow",
      "description": "Request a diff between version 1 and version 2.",
      "item": [
        {
          "name": "Get Diff (v1 → v2)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/documents/{{doc_id}}/versions/diff?from={{version_id}}&to={{v2_version_id}}",
              "host": ["{{base_url}}"],
              "path": ["documents", "{{doc_id}}", "versions", "diff"],
              "query": [
                { "key": "from", "value": "{{version_id}}" },
                { "key": "to", "value": "{{v2_version_id}}" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200 or 202', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 202]);",
                  "});",
                  "",
                  "pm.test('Diff response has expected structure (if 200)', function () {",
                  "    if (pm.response.code === 200) {",
                  "        const body = pm.response.json();",
                  "        pm.expect(body).to.have.property('from_version_id');",
                  "        pm.expect(body).to.have.property('to_version_id');",
                  "        pm.expect(body).to.have.property('diff');",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": []
        }
      ]
    },
    {
      "name": "Comments Flow",
      "description": "Add and list comments on a version.",
      "item": [
        {
