                  "    const body = pm.response.json();",
                  "    pm.expect(body.doc_id).to.eql(pm.collectionVariables.get('doc_id'));",
                  "});",
                  "",
                  "pm.test('Version has expected fields', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('id');",
                  "    pm.expect(body).to.have.property('version_number');",
                  "    pm.expect(body).to.have.property('status');",
                  "    pm.expect(body).to.have.property('is_draft');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": []
        }
      ]
    },
    {
      "name": "Download Flow",
      "description": "Download version files via presigned URLs.",
      "item": [
        {
          "name": "Get v1 Download URL",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/documents/{{doc_id}}/versions/{{version_id}}/download",
              "host": ["{{base_url}}"],
              "path": ["documents", "{{doc_id}}", "versions", "{{version_id}}", "download"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200 or 202', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 202]);",
                  "});",
                  "",
                  "pm.test('Rewrite and store download_url (if 200)', function () {",
                  "    if (pm.response.code === 200) {",
                  "        const body = pm.response.json();",
                  "        pm.expect(body).to.have.property('download_url');",
                  "        const internalHost = pm.collectionVariables.get('s3_internal_host');",
                  "        const externalHost = pm.collectionVariables.get('s3_external_host');",
                  "        const rewritten = body.download_url.replace(internalHost, externalHost);",
                  "        pm.collectionVariables.set('download_url', rewritten);",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "response": []
        },
        {
          "name": "Download v1 file from S3",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{download_url}}",
              "host": ["{{download_url}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
